# Neon Postgres connection string (https://neon.com/docs) — used by Prisma
DATABASE_URL=
# After cloning: `npm i` then `npx prisma migrate deploy` (prod) or `npx prisma db push` (dev)

# Neon Auth — enable Auth in the Neon Console, then copy Auth URL from Project → Branch → Auth → Configuration
# Overview: https://neon.com/docs/auth/overview — Next.js: https://neon.com/docs/auth/quick-start/nextjs-api-only
# Verification / password-reset emails: Console → Auth → enable “Verify at sign-up” and configure an email provider
# (shared or custom SMTP). See https://neon.com/docs/auth/guides/email-verification and production checklist.
NEON_AUTH_BASE_URL=
# NOT from the Neon UI: you generate this locally. Required by createNeonAuth() for signing session cookies (HMAC-SHA256).
# Documented: https://neon.com/docs/auth/reference/nextjs-server#environment-variables — use openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=
# Neon Auth -> Webhooks: add https://<your-domain>/api/auth/webhook subscribed to
# send.otp, send.password_reset, user.before_create. Copy the signing key here.
# Our handler verifies the Ed25519 detached-JWS signature against the JWKS at
# ${NEON_AUTH_BASE_URL}/.well-known/jwks.json and dispatches the event to
# Resend via src/lib/email.ts. See docs/onboarding-runbook.md.
NEON_AUTH_WEBHOOK_SIGNING_KEY=

# Resend (https://resend.com) - transactional email for signup/password-reset
# and saved-search digests. `EMAIL_FROM` must match a verified Resend domain.
RESEND_API_KEY=
EMAIL_FROM="Plott <hello@plott.uk>"
# Optional: Resend audience/list used by /api/marketing/subscribe.
RESEND_MARKETING_AUDIENCE_ID=4c6e03f9-3f6f-4f6b-a35e-d70b9011e172
# Published Resend template used only for Plott agent prospect outreach sends.
RESEND_AGENT_OUTREACH_TEMPLATE_ID=c5654e09-9776-4522-94d9-7da349624130
# Inbox that receives /contact and /support form submissions.
# Defaults to support@plott.uk when unset.
CONTACT_INBOX_EMAIL=
# Optional salt for hashing lead-capture IP/user-agent audit fields.
MARKETING_LEAD_HASH_SALT=

# App URL (used in Stripe redirects). On Vercel, set this to the URL users open (production or preview).
# Neon Auth "Invalid origin" / 403: Console → Auth → Configuration → Domains must list every origin
# you use — e.g. https://your-app.vercel.app and https://your-custom-domain.com — each preview
# deployment has its own *.vercel.app hostname; wildcards are not supported (see
# https://neon.com/docs/auth/guides/configure-domains ).
# IMPORTANT: Set to https://plott.uk in production for correct email links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps Platform — public browser key + Map ID for map/3D views; static key is server-only.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
GOOGLE_MAPS_STATIC_API_KEY=

# Vercel Blob — required for production logo/signature/PDF storage.
BLOB_READ_WRITE_TOKEN=

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs for each subscription tier — copy from Stripe dashboard → Products.
# These determine which AI features are available (see src/lib/ai/tiers.ts).
# If a company's subscriptionPriceId doesn't match any of these, they default to Free tier.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
# Metered price for AI overage billing (1 unit = 1 penny of overage charge).
# Create via: stripe prices create --currency=gbp --product=<product_id> --recurring.usage-type=metered --recurring.meter=<meter_id> --unit-amount=1
STRIPE_PRICE_AI_OVERAGE=
# Optional: enable if Stripe Tax is on in the Dashboard (see docs/stripe-new-account.md).
# STRIPE_AUTOMATIC_TAX=true
# Optional: trial days for new subscriptions (default 14).
# STRIPE_TRIAL_DAYS=14

# PlanWire API (https://planwire.io)
PLANWIRE_API_KEY=

# Hunter API (https://hunter.io/api-documentation/v2) — optional structured email enrichment for outreach contacts
HUNTER_API_KEY=

# PropertyData API (https://propertydata.co.uk/api/documentation) — UPRN/title and Land Registry document purchase (server-only; never expose key to the client)
PROPERTYDATA_API_KEY=

# Optional: local dev only — treats subscription as active when true
SKIP_SUBSCRIPTION_CHECK=false

# Optional: local dev only — treats every Neon Auth session as email-verified,
# bypassing the OTP step. Useful when the Resend sender domain isn't verified
# yet (so OTP emails can't actually be delivered) or you don't have a public
# webhook URL to receive send.otp events. Double-gated on NODE_ENV/VERCEL_ENV
# so setting this in production has no effect.
DEV_SKIP_EMAIL_VERIFICATION=false

# Vercel AI Gateway — https://vercel.com/docs/ai-gateway
# All agents (Claude Sonnet/Haiku, GPT-4.1, Gemini) route through the gateway.
# Not required in Vercel deployments (OIDC auto-injected); only set locally.
AI_GATEWAY_API_KEY=
# Cost-tracking knobs (see src/lib/ai/router.ts + src/lib/ai/guardrails.ts).
# AI_USD_GBP_RATE is only a fallback used when the live FX lookup fails —
# see src/lib/fx.ts (Frankfurter / ECB reference rates).
AI_USD_GBP_RATE=0.78
AI_DAILY_BUDGET_GBP_DEFAULT=5

# Rate limiting. Code auto-detects Vercel KV (KV_REST_API_URL /
# KV_REST_API_TOKEN, injected by the Vercel KV integration). For standalone
# Upstash Redis, set these two explicitly. Missing/broken Redis fails closed in
# production, so configure one of these before launch.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron auth — required for /api/cron/* routes in production.
CRON_SECRET=
